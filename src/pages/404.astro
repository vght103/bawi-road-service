---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="페이지를 찾을 수 없습니다"
  description="요청하신 페이지가 존재하지 않습니다."
  path="/404"
>
  <section class="min-h-[60vh] flex items-center justify-center px-6">
    <div class="text-center max-w-md">
      <p class="text-[5rem] font-black text-terracotta leading-none">404</p>
      <h1 class="text-[1.5rem] font-bold text-brown-dark mt-4">
        페이지를 찾을 수 없습니다
      </h1>
      <p class="text-brown mt-3 leading-relaxed">
        요청하신 페이지가 존재하지 않거나, 주소가 변경되었을 수 있습니다.
      </p>
      <div class="flex gap-3 justify-center mt-8">
        <a
          href="/"
          class="bg-terracotta text-white px-6 py-3 rounded-lg font-semibold text-[0.9rem] hover:bg-terracotta-hover transition-colors no-underline"
        >
          홈으로 돌아가기
        </a>
        <a
          href="/academies"
          class="border border-beige-dark text-brown-dark px-6 py-3 rounded-lg font-semibold text-[0.9rem] hover:bg-beige transition-colors no-underline"
        >
          어학원 둘러보기
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
