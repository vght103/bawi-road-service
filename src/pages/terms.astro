---
import BaseLayout from "@/layouts/BaseLayout.astro";
import TermsRenderer from "@/components/legal/TermsRenderer.astro";
import { TERMS_OF_SERVICE } from "@/data/legal/terms-of-service";
---

<BaseLayout
  title="이용약관"
  description="바위로드 이용약관. 서비스의 이용, 회원 가입, 탈퇴, 책임 제한 등에 관한 사항을 안내합니다."
  path="/terms"
>
  <div class="bg-cream min-h-screen pt-24 pb-20 px-5">
    <article class="max-w-[800px] mx-auto prose prose-neutral prose-sm leading-relaxed">
      <h1 class="text-2xl font-bold text-brown-dark mb-1">{TERMS_OF_SERVICE.pageTitle}</h1>
      <p class="text-brown text-sm mb-10">시행일: {TERMS_OF_SERVICE.effectiveDate}</p>

      <TermsRenderer articles={TERMS_OF_SERVICE.articles} />

      <p class="mt-10 font-semibold text-brown-dark">
        시행일: {TERMS_OF_SERVICE.effectiveDate}
      </p>
    </article>
  </div>
</BaseLayout>
