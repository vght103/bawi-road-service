{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strictNullChecks": true,
    "verbatimModuleSyntax": false,
    "erasableSyntaxOnly": true
  },
  "include": ["src", ".astro"]
}
